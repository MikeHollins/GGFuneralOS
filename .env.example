# GGFuneralOS Environment Configuration
# Copy to .env and fill in your values

# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/ggfuneralos?sslmode=require

# Twilio (for Intake Agent SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+19894655467

# LLM (for obituary/program generation)
GOOGLE_AI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Social Media APIs
FACEBOOK_PAGE_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
LINKEDIN_ACCESS_TOKEN=

# Server
PORT=4000
API_SECRET=changeme-to-a-random-string

# Funeral Home Info
FUNERAL_HOME_NAME=KC Golden Gate Funeral Home
FUNERAL_HOME_PHONE=
FUNERAL_HOME_ADDRESS=
FUNERAL_HOME_WEBSITE=https://kcgoldengate.com
