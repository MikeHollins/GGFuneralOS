# GGFuneralOS Environment Configuration
# Copy to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/ggfuneralos?sslmode=require

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=generate-a-64-char-random-string
API_SECRET=another-random-string-for-max-bridge

# ─── Twilio (Intake Agent SMS) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+19894655467

# ─── Google AI (Obituary Generation) ────────────────────────────────────────
GOOGLE_AI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe (Payments — Apple Pay, Google Pay) ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── DocuSign (E-Signatures) ────────────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_PRIVATE_KEY=

# ─── SendGrid (Emails) ──────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=info@kcgoldengate.com

# ─── Social Media ────────────────────────────────────────────────────────────
FACEBOOK_PAGE_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

# ─── Google Business Profile ────────────────────────────────────────────────
GOOGLE_BUSINESS_ACCESS_TOKEN=
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=
GOOGLE_PLACE_ID=
GOOGLE_REVIEW_URL=https://g.page/kcgoldengate/review

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
PUBLIC_URL=https://your-api-domain.com
DASHBOARD_URL=https://your-dashboard-domain.vercel.app

# ─── Funeral Home Info ───────────────────────────────────────────────────────
FUNERAL_HOME_NAME=KC Golden Gate Funeral Home
FUNERAL_HOME_PHONE=(816) 231-GATE
FUNERAL_HOME_ADDRESS=2800 E 18th St, Kansas City, MO 64127
FUNERAL_HOME_WEBSITE=https://kcgoldengate.com
