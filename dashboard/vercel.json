{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ggfuneralos-api.up.railway.app/api/:path*"
    },
    {
      "source": "/program/:path*",
      "destination": "https://ggfuneralos-api.up.railway.app/program/:path*"
    }
  ],
  "headers": [
    {
      "source": "/program/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
