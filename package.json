{
  "name": "gg-funeral-os",
  "version": "0.2.0",
  "description": "GGFuneralOS — Funeral home operating system for KC Golden Gate",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:push": "tsx src/db/push-schema.ts",
    "db:migrate": "tsx src/db/push-schema.ts && echo 'Running migration...' && tsx -e \"require('./src/db/client').sql(require('fs').readFileSync('src/db/migrations/001-upgrade-tables.sql','utf8'))\"",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@neondatabase/serverless": "^0.10.0",
    "@sendgrid/mail": "^8.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.0",
    "pdfkit": "^0.15.0",
    "playwright": "^1.59.1",
    "qrcode": "^1.5.4",
    "stripe": "^17.0.0",
    "twilio": "^5.0.0",
    "uuid": "^10.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/pdfkit": "^0.13.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.6.0"
  }
}
